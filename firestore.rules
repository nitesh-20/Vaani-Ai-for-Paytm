rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - uid: string (required)
    //   - name: string (required)
    //   - role: string (required, 'merchant' or 'customer')
    //   - email: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: transactions
    // Document ID: transactionId
    // Fields:
    //   - amount: number (required)
    //   - currency: string (required)
    //   - timestamp: timestamp (required)
    //   - merchantId: string (required)
    //   - customerId: string (required)
    //   - customerName: string (required)
    //   - merchantName: string (required)
    //   - category: string (required)
    //   - status: string (required, 'success', 'failed', 'pending')
    //   - referenceId: string (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }

    function isDemoUser(userId) {
      return userId == 'demo-user';
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'role']) &&
             data.uid is string &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.role in ['merchant', 'customer'];
    }

    function isValidTransaction(data) {
      return data.keys().hasAll(['amount', 'currency', 'timestamp', 'merchantId', 'customerId', 'status']) &&
             data.amount is number && data.amount > 0 &&
             data.currency is string &&
             data.merchantId is string &&
             data.customerId is string &&
             data.status in ['success', 'failed', 'pending'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isAuthenticated() || isDemoUser(userId);
      allow create, update: if (isAuthenticated() && (request.auth.uid == userId || isAdmin())) || isDemoUser(userId);
    }

    match /transactions/{transactionId} {
      allow read: if isAuthenticated() || isDemoUser(resource.data.merchantId) || isDemoUser(resource.data.customerId);
      allow create, update: if isAuthenticated() || isDemoUser(request.resource.data.merchantId) || isDemoUser(request.resource.data.customerId);
    }

    match /conversations/{conversationId} {
      allow read: if (isAuthenticated() && (resource.data.userId == request.auth.uid || isAdmin())) || isDemoUser(resource.data.userId);
      allow create: if (isAuthenticated() && request.resource.data.userId == request.auth.uid) || isDemoUser(request.resource.data.userId);
      allow update: if (isAuthenticated() && resource.data.userId == request.auth.uid) || isDemoUser(request.resource.data.userId);
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "iamshreedshrivastava@gmail.com" && request.auth.token.email_verified == true));
    }
  }
}
